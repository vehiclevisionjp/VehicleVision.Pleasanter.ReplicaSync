{
  "private": true,
  "scripts": {
    "preinstall:check": "node -e \"const fs=require('fs');if(!fs.existsSync('node_modules')){process.exit(1)}\" || npm install",
    "setup": "npm install",
    "lint:md": "npm run preinstall:check && markdownlint-cli2 \"docs/**/*.md\" \"*.md\"",
    "lint:md:fix": "npm run preinstall:check && markdownlint-cli2 --fix \"docs/**/*.md\" \"*.md\"",
    "format": "npm run preinstall:check && prettier --write \"docs/**/*.md\" \"*.md\"",
    "format:check": "npm run preinstall:check && prettier --check \"docs/**/*.md\" \"*.md\"",
    "toc": "npm run preinstall:check && doctoc docs README.md CONTRIBUTING.md --github --maxlevel 3 --notitle && node docs/script/decode-toc.js",
    "toc:file": "doctoc --github --maxlevel 3 --notitle",
    "toc:all": "npm run toc && npm run format",
    "pdf": "npm run preinstall:check && node docs/script/generate-pdf.js",
    "pdf:wiki": "npm run preinstall:check && node docs/script/generate-pdf.js docs/wiki/**/*.md",
    "submodule:init": "git submodule update --init --recursive",
    "submodule:update": "git submodule update --remote --merge",
    "submodule:status": "git submodule status"
  },
  "devDependencies": {
    "doctoc": "^2.2.1",
    "glob": "^11.0.0",
    "markdownlint": "^0.40.0",
    "markdownlint-cli2": "^0.20.0",
    "md-to-pdf": "^5.2.4",
    "prettier": "^3.5.0",
    "yaml": "^2.8.2"
  }
}
