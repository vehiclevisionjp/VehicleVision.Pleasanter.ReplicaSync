@page "/users"
@using Microsoft.AspNetCore.Authorization
@using VehicleVision.Pleasanter.ReplicaSync.Core.Enums
@using VehicleVision.Pleasanter.ReplicaSync.Core.Interfaces
@using VehicleVision.Pleasanter.ReplicaSync.Core.Models
@attribute [Authorize(Policy = "AdminOnly")]
@inject IAppUserRepository UserRepo
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>ユーザー管理</PageTitle>

<h1>ユーザー管理</h1>

<div class="mb-3">
    <a href="users/create" class="btn btn-primary">
        <span class="bi bi-person-plus" aria-hidden="true"></span> 新規作成
    </a>
</div>

@if (_loading)
{
    <p><em>読み込み中...</em></p>
}
else if (_errorMessage is not null)
{
    <div class="alert alert-danger">@_errorMessage</div>
}
else if (_users.Count == 0)
{
    <div class="alert alert-info">ユーザーが登録されていません。</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>ID</th>
                <th>ユーザー名</th>
                <th>ロール</th>
                <th>パスワード変更必須</th>
                <th>作成日時</th>
                <th>更新日時</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in _users)
            {
                <tr>
                    <td>@user.Id</td>
                    <td>@user.Username</td>
                    <td>
                        @if (user.Role == AppRole.Administrator)
                        {
                            <span class="badge bg-danger">管理者</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">一般</span>
                        }
                    </td>
                    <td>
                        @if (user.MustChangePassword)
                        {
                            <span class="badge bg-warning text-dark">要変更</span>
                        }
                        else
                        {
                            <span class="badge bg-success">済</span>
                        }
                    </td>
                    <td>@user.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@user.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>
                        <a href="users/edit/@user.Id" class="btn btn-sm btn-outline-primary">編集</a>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => ShowDeleteConfirmation(user)"
                                disabled="@IsCurrentUser(user)">削除</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (_deleteConfirmUser is not null)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">削除確認</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>ユーザー「@_deleteConfirmUser.Username」を削除しますか？</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">キャンセル</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDeleteAsync">削除</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private string? _errorMessage;
    private IReadOnlyList<AppUser> _users = [];
    private AppUser? _deleteConfirmUser;

    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        try
        {
            _users = await UserRepo.GetAllAsync();
            _errorMessage = null;
        }
        catch (Exception ex)
        {
            _errorMessage = $"データの読み込みに失敗しました: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private bool IsCurrentUser(AppUser user)
    {
        var currentUsername = HttpContext?.User.Identity?.Name;
        return string.Equals(user.Username, currentUsername, StringComparison.OrdinalIgnoreCase);
    }

    private void ShowDeleteConfirmation(AppUser user)
    {
        _deleteConfirmUser = user;
    }

    private void CancelDelete()
    {
        _deleteConfirmUser = null;
    }

    private async Task ConfirmDeleteAsync()
    {
        if (_deleteConfirmUser is null) return;

        try
        {
            await UserRepo.DeleteAsync(_deleteConfirmUser.Id);
            _deleteConfirmUser = null;
            await LoadUsersAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"削除に失敗しました: {ex.Message}";
            _deleteConfirmUser = null;
        }
    }
}