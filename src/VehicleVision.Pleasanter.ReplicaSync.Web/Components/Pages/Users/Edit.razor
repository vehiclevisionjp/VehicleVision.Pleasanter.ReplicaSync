@page "/users/edit/{Id:int}"
@using Microsoft.AspNetCore.Authorization
@using VehicleVision.Pleasanter.ReplicaSync.Core.Enums
@using VehicleVision.Pleasanter.ReplicaSync.Core.Interfaces
@using VehicleVision.Pleasanter.ReplicaSync.Core.Models
@using VehicleVision.Pleasanter.ReplicaSync.Web.Security
@attribute [Authorize(Policy = "AdminOnly")]
@inject IAppUserRepository UserRepo
@inject NavigationManager Navigation
@inject ILogger<Edit> Logger
@rendermode InteractiveServer

<PageTitle>ユーザー編集</PageTitle>

<h1>ユーザー編集</h1>

@if (_loading)
{
    <p><em>読み込み中...</em></p>
}
else if (_user is null)
{
    <div class="alert alert-danger">ユーザーが見つかりません。</div>
    <a href="users" class="btn btn-secondary">戻る</a>
}
else
{
    <div class="row">
        <div class="col-md-6">
            @if (_errorMessage is not null)
            {
                <div class="alert alert-danger">@_errorMessage</div>
            }
            @if (_successMessage is not null)
            {
                <div class="alert alert-success">@_successMessage</div>
            }

            <form @onsubmit="HandleSubmitAsync">
                <div class="mb-3">
                    <label for="username" class="form-label">ユーザー名</label>
                    <input type="text" class="form-control" id="username" @bind="_username" required maxlength="100"
                           autocomplete="off" />
                </div>

                <div class="mb-3">
                    <label for="role" class="form-label">ロール</label>
                    <select id="role" class="form-select" @bind="_role" disabled="@_isSelf">
                        <option value="@AppRole.User">一般</option>
                        <option value="@AppRole.Administrator">管理者</option>
                    </select>
                    @if (_isSelf)
                    {
                        <div class="form-text text-muted">自分自身のロールは変更できません。</div>
                    }
                </div>

                <div class="mb-3 form-check">
                    <input type="checkbox" class="form-check-input" id="mustChangePassword"                           @bind="_mustChangePassword" />
                    <label class="form-check-label" for="mustChangePassword">次回ログイン時にパスワード変更を強制</label>
                </div>

                <hr />

                <h5>パスワードリセット</h5>
                <p class="text-muted">空白のままにするとパスワードは変更されません。</p>

                <div class="mb-3">
                    <label for="newPassword" class="form-label">新しいパスワード</label>
                    <input type="password" class="form-control" id="newPassword" @bind="_newPassword"
                           autocomplete="new-password" />
                </div>

                <div class="mb-3">
                    <label for="confirmPassword" class="form-label">新しいパスワード（確認）</label>
                    <input type="password" class="form-control" id="confirmPassword" @bind="_confirmPassword"
                           autocomplete="new-password" />
                </div>

                <div class="mb-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary" disabled="@_submitting">
                        @if (_submitting)
                        {
                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                            <span>更新中...</span>
                        }
                        else
                        {
                            <span>更新</span>
                        }
                    </button>
                    <a href="users" class="btn btn-secondary">キャンセル</a>
                </div>
            </form>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private AppUser? _user;
    private bool _loading = true;
    private bool _submitting;
    private bool _isSelf;
    private string _username = string.Empty;
    private AppRole _role;
    private bool _mustChangePassword;
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private string? _errorMessage;
    private string? _successMessage;

    protected override async Task OnInitializedAsync()
    {
        _user = await UserRepo.GetByIdAsync(Id);
        if (_user is not null)
        {
            _username = _user.Username;
            _role = _user.Role;
            _mustChangePassword = _user.MustChangePassword;

            var currentUsername = HttpContext?.User.Identity?.Name;
            _isSelf = string.Equals(_user.Username, currentUsername, StringComparison.OrdinalIgnoreCase);
        }

        _loading = false;
    }

    private async Task HandleSubmitAsync()
    {
        if (_user is null) return;

        _submitting = true;
        _errorMessage = null;
        _successMessage = null;

        try
        {
            // Validate password if provided
            if (!string.IsNullOrEmpty(_newPassword))
            {
                if (_newPassword != _confirmPassword)
                {
                    _errorMessage = "新しいパスワードが一致しません。";
                    return;
                }

                if (_newPassword.Length < 8)
                {
                    _errorMessage = "パスワードは8文字以上で入力してください。";
                    return;
                }

                _user.PasswordHash = PasswordHasher.HashPassword(_newPassword);
            }

            // Check username uniqueness if changed
            if (!string.Equals(_user.Username, _username, StringComparison.Ordinal))
            {
                var existing = await UserRepo.GetByUsernameAsync(_username);
                if (existing is not null)
                {
                    _errorMessage = $"ユーザー名「{_username}」は既に使用されています。";
                    return;
                }

                _user.Username = _username;
            }

            // Prevent self-demotion
            if (!_isSelf)
            {
                _user.Role = _role;
            }

            _user.MustChangePassword = _mustChangePassword;

            await UserRepo.UpdateAsync(_user);
            Logger.LogInformation("ユーザー '{Username}' (ID: {UserId}) を更新しました。", _user.Username, _user.Id);
            _successMessage = "ユーザー情報を更新しました。";

            // Reset password fields
            _newPassword = string.Empty;
            _confirmPassword = string.Empty;
        }
        catch (Exception ex)
        {
            _errorMessage = $"更新に失敗しました: {ex.Message}";
        }
        finally
        {
            _submitting = false;
        }
    }
}