@page "/instances"
@using VehicleVision.Pleasanter.ReplicaSync.Core.Interfaces
@using VehicleVision.Pleasanter.ReplicaSync.Core.Models
@inject ISyncConfigRepository ConfigRepo
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>インスタンス管理</PageTitle>

<h1>インスタンス管理</h1>

<div class="mb-3">
    <a href="instances/create" class="btn btn-primary">
        <span class="bi bi-plus-circle" aria-hidden="true"></span> 新規作成
    </a>
</div>

@if (_loading)
{
    <p><em>読み込み中...</em></p>
}
else if (_errorMessage is not null)
{
    <div class="alert alert-danger">@_errorMessage</div>
}
else if (_instances.Count == 0)
{
    <div class="alert alert-info">インスタンスが登録されていません。</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>ID</th>
                <th>インスタンスID</th>
                <th>表示名</th>
                <th>DBタイプ</th>
                <th>作成日時</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var instance in _instances)
            {
                <tr>
                    <td>@instance.Id</td>
                    <td>@instance.InstanceId</td>
                    <td>@instance.DisplayName</td>
                    <td><span class="badge bg-secondary">@instance.DbmsType</span></td>
                    <td>@instance.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>
                        <a href="instances/edit/@instance.Id" class="btn btn-sm btn-outline-primary">編集</a>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => ShowDeleteConfirmation(instance)">削除</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (_deleteConfirmInstance is not null)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">削除確認</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>インスタンス「@_deleteConfirmInstance.DisplayName」を削除しますか？</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete">キャンセル</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDeleteAsync">削除</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private string? _errorMessage;
    private IReadOnlyList<SyncInstance> _instances = [];
    private SyncInstance? _deleteConfirmInstance;

    protected override async Task OnInitializedAsync()
    {
        await LoadInstancesAsync();
    }

    private async Task LoadInstancesAsync()
    {
        try
        {
            _instances = await ConfigRepo.GetAllInstancesAsync();
            _errorMessage = null;
        }
        catch (Exception ex)
        {
            _errorMessage = $"データの読み込みに失敗しました: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void ShowDeleteConfirmation(SyncInstance instance)
    {
        _deleteConfirmInstance = instance;
    }

    private void CancelDelete()
    {
        _deleteConfirmInstance = null;
    }

    private async Task ConfirmDeleteAsync()
    {
        if (_deleteConfirmInstance is null) return;

        try
        {
            await ConfigRepo.DeleteInstanceAsync(_deleteConfirmInstance.Id);
            _deleteConfirmInstance = null;
            await LoadInstancesAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"削除に失敗しました: {ex.Message}";
            _deleteConfirmInstance = null;
        }
    }
}
