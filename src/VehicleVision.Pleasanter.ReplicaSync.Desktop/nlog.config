<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" autoReload="true" throwConfigExceptions="true" internalLogLevel="Warn" internalLogFile="${basedir}/logs/nlog-internal.log">

  <extensions>
    <add assembly="NLog.Web.AspNetCore" />
  </extensions>

  <targets>
    <!-- コンソール出力 -->
    <target xsi:type="ColoredConsole" name="console" layout="${longdate}|${level:uppercase=true:padding=-5}|${logger:shortName=true}|${message}${onexception:inner=${newline}${exception:format=tostring}}" />

    <!-- デバッグコンソール出力 -->
    <target xsi:type="Debugger" name="debugger" layout="${longdate}|${level:uppercase=true:padding=-5}|${logger:shortName=true}|${message}${onexception:inner=${newline}${exception:format=tostring}}" />

    <!-- ファイル出力（日付ローテーション） -->
    <target xsi:type="File" name="file" fileName="${basedir}/logs/replicasync-desktop-${shortdate}.log" layout="${longdate}|${level:uppercase=true:padding=-5}|${logger}|${message}${onexception:inner=${newline}${exception:format=tostring}}" archiveAboveSize="10485760" maxArchiveFiles="30" encoding="utf-8" />

    <!-- エラー専用ファイル出力 -->
    <target xsi:type="File" name="errorFile" fileName="${basedir}/logs/replicasync-desktop-error-${shortdate}.log" layout="${longdate}|${level:uppercase=true:padding=-5}|${logger}|${message}${onexception:inner=${newline}${exception:format=tostring}}" archiveAboveSize="10485760" maxArchiveFiles="30" encoding="utf-8" />
  </targets>

  <rules>
    <!-- Microsoft/ASP.NET の詳細ログは Warning 以上のみ -->
    <logger name="Microsoft.AspNetCore.*" maxlevel="Info" final="true" />
    <logger name="Microsoft.*" maxlevel="Info" final="true" />
    <logger name="System.Net.Http.*" maxlevel="Info" final="true" />

    <!-- エラー・致命的ログはエラー専用ファイルにも出力 -->
    <logger name="*" minlevel="Error" writeTo="errorFile" />

    <!-- 全ログをコンソール・デバッガー・ファイルに出力 -->
    <logger name="*" minlevel="Debug" writeTo="console,debugger,file" />
  </rules>
</nlog>
