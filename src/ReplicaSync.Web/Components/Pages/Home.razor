@page "/"
@using ReplicaSync.Core.Interfaces
@inject ISyncConfigRepository ConfigRepo
@rendermode InteractiveServer

<PageTitle>ReplicaSync - ホーム</PageTitle>

<h1>ReplicaSync ダッシュボード</h1>
<p>プリザンターインスタンス間データ同期管理</p>

@if (_loading)
{
    <p><em>読み込み中...</em></p>
}
else
{
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card text-bg-primary">
                <div class="card-body">
                    <h5 class="card-title">インスタンス</h5>
                    <p class="card-text display-4">@_instanceCount</p>
                    <a href="instances" class="btn btn-light btn-sm">管理</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-bg-success">
                <div class="card-body">
                    <h5 class="card-title">同期定義</h5>
                    <p class="card-text display-4">@_definitionCount</p>
                    <a href="sync-definitions" class="btn btn-light btn-sm">管理</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-bg-info">
                <div class="card-body">
                    <h5 class="card-title">最近のログ</h5>
                    <p class="card-text display-4">@_recentLogCount</p>
                    <a href="sync-logs" class="btn btn-light btn-sm">詳細</a>
                </div>
            </div>
        </div>
    </div>

    @if (_recentLogs.Count > 0)
    {
        <h3>最近の同期ログ</h3>
        <table class="table table-striped table-sm">
            <thead>
                <tr>
                    <th>同期ID</th>
                    <th>ステータス</th>
                    <th>処理件数</th>
                    <th>開始時刻</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in _recentLogs.Take(10))
                {
                    <tr>
                        <td>@log.SyncId</td>
                        <td><span class="badge @GetStatusBadgeClass(log.Status)">@log.Status</span></td>
                        <td>@log.RecordsProcessed</td>
                        <td>@log.StartedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    private bool _loading = true;
    private int _instanceCount;
    private int _definitionCount;
    private int _recentLogCount;
    private IReadOnlyList<ReplicaSync.Core.Models.SyncLogEntry> _recentLogs = [];

    protected override async Task OnInitializedAsync()
    {
        var instances = await ConfigRepo.GetAllInstancesAsync();
        _instanceCount = instances.Count;

        var definitions = await ConfigRepo.GetAllDefinitionsAsync();
        _definitionCount = definitions.Count;

        _recentLogs = await ConfigRepo.GetRecentLogsAsync(10);
        _recentLogCount = _recentLogs.Count;

        _loading = false;
    }

    private static string GetStatusBadgeClass(ReplicaSync.Core.Enums.SyncStatus status) => status switch
    {
        ReplicaSync.Core.Enums.SyncStatus.Success => "bg-success",
        ReplicaSync.Core.Enums.SyncStatus.Failed => "bg-danger",
        ReplicaSync.Core.Enums.SyncStatus.Conflict => "bg-warning",
        ReplicaSync.Core.Enums.SyncStatus.Skipped => "bg-secondary",
        _ => "bg-secondary"
    };
}
