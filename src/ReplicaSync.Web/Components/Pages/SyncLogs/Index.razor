@page "/sync-logs"
@using ReplicaSync.Core.Enums
@using ReplicaSync.Core.Interfaces
@using ReplicaSync.Core.Models
@inject ISyncConfigRepository ConfigRepo
@rendermode InteractiveServer

<PageTitle>同期ログ</PageTitle>

<h1>同期ログ</h1>

@if (_errorMessage is not null)
{
    <div class="alert alert-danger">@_errorMessage</div>
}

<div class="row mb-3">
    <div class="col-md-4">
        <label for="filterSyncId" class="form-label">同期IDでフィルター</label>
        <input type="text" id="filterSyncId" class="form-control" @bind="_filterSyncId" @bind:event="oninput" placeholder="同期IDを入力..." />
    </div>
    <div class="col-md-3">
        <label for="filterStatus" class="form-label">ステータス</label>
        <select id="filterStatus" class="form-select" @bind="_filterStatus">
            <option value="">すべて</option>
            @foreach (var status in Enum.GetValues<SyncStatus>())
            {
                <option value="@status">@status</option>
            }
        </select>
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <button class="btn btn-primary" @onclick="ApplyFilterAsync">フィルター</button>
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <button class="btn btn-outline-secondary" @onclick="ClearFilterAsync">クリア</button>
    </div>
</div>

@if (_loading)
{
    <p><em>読み込み中...</em></p>
}
else if (_filteredLogs.Count == 0)
{
    <div class="alert alert-info">同期ログがありません。</div>
}
else
{
    <table class="table table-striped table-hover table-sm">
        <thead>
            <tr>
                <th>ID</th>
                <th>同期ID</th>
                <th>ソース</th>
                <th>ターゲット</th>
                <th>ステータス</th>
                <th>処理件数</th>
                <th>挿入</th>
                <th>更新</th>
                <th>削除</th>
                <th>競合</th>
                <th>開始時刻</th>
                <th>完了時刻</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in _filteredLogs)
            {
                <tr>
                    <td>@log.Id</td>
                    <td>@log.SyncId</td>
                    <td>@log.SourceInstanceId</td>
                    <td>@log.TargetInstanceId</td>
                    <td><span class="badge @GetStatusBadgeClass(log.Status)">@log.Status</span></td>
                    <td>@log.RecordsProcessed</td>
                    <td>@log.RecordsInserted</td>
                    <td>@log.RecordsUpdated</td>
                    <td>@log.RecordsDeleted</td>
                    <td>@log.ConflictsDetected</td>
                    <td>@log.StartedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td>@(log.CompletedAt?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td>
                </tr>
                @if (!string.IsNullOrEmpty(log.ErrorMessage))
                {
                    <tr>
                        <td colspan="12">
                            <div class="alert alert-danger py-1 px-2 mb-0 small">
                                @log.ErrorMessage
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
}

@code {
    private bool _loading = true;
    private string? _errorMessage;
    private string _filterSyncId = string.Empty;
    private string _filterStatus = string.Empty;
    private IReadOnlyList<SyncLogEntry> _allLogs = [];
    private IReadOnlyList<SyncLogEntry> _filteredLogs = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadLogsAsync();
    }

    private async Task LoadLogsAsync()
    {
        try
        {
            _allLogs = await ConfigRepo.GetRecentLogsAsync(100);
            ApplyFilter();
            _errorMessage = null;
        }
        catch (Exception ex)
        {
            _errorMessage = $"データの読み込みに失敗しました: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void ApplyFilter()
    {
        var filtered = _allLogs.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(_filterSyncId))
        {
            filtered = filtered.Where(l =>
                l.SyncId.Contains(_filterSyncId, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrWhiteSpace(_filterStatus) &&
            Enum.TryParse<SyncStatus>(_filterStatus, out var status))
        {
            filtered = filtered.Where(l => l.Status == status);
        }

        _filteredLogs = filtered.ToList();
    }

    private Task ApplyFilterAsync()
    {
        ApplyFilter();
        return Task.CompletedTask;
    }

    private async Task ClearFilterAsync()
    {
        _filterSyncId = string.Empty;
        _filterStatus = string.Empty;
        await LoadLogsAsync();
    }

    private static string GetStatusBadgeClass(SyncStatus status) => status switch
    {
        SyncStatus.Success => "bg-success",
        SyncStatus.Failed => "bg-danger",
        SyncStatus.Conflict => "bg-warning",
        SyncStatus.Skipped => "bg-secondary",
        _ => "bg-secondary"
    };
}
