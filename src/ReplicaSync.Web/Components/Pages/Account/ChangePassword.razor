@page "/account/change-password"
@using System.Security.Claims
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using ReplicaSync.Core.Interfaces
@using ReplicaSync.Web.Security
@layout ReplicaSync.Web.Components.Layout.LoginLayout
@inject IAppUserRepository UserRepo
@inject NavigationManager Navigation
@inject ILogger<ChangePassword> Logger

<PageTitle>パスワード変更 - ReplicaSync</PageTitle>

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow">
            <div class="card-body">
                <h3 class="card-title text-center mb-4">パスワード変更</h3>
                @if (_mustChange)
                {
                    <div class="alert alert-warning">初回ログインのため、パスワードを変更してください。</div>
                }
                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="alert alert-danger">@_errorMessage</div>
                }
                @if (!string.IsNullOrEmpty(_successMessage))
                {
                    <div class="alert alert-success">@_successMessage</div>
                }
                <form method="post" @formname="ChangePasswordForm" @onsubmit="HandleChangePasswordAsync">
                    <AntiforgeryToken />
                    <div class="mb-3">
                        <label for="currentPassword" class="form-label">現在のパスワード</label>
                        <input type="password" class="form-control" id="currentPassword" name="CurrentPassword"
                               value="@CurrentPassword" required autocomplete="current-password" />
                    </div>
                    <div class="mb-3">
                        <label for="newPassword" class="form-label">新しいパスワード</label>
                        <input type="password" class="form-control" id="newPassword" name="NewPassword"
                               value="@NewPassword" required autocomplete="new-password" />
                    </div>
                    <div class="mb-3">
                        <label for="confirmPassword" class="form-label">新しいパスワード（確認）</label>
                        <input type="password" class="form-control" id="confirmPassword" name="ConfirmPassword"
                               value="@ConfirmPassword" required autocomplete="new-password" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">変更</button>
                </form>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromForm]
    private string? CurrentPassword { get; set; }

    [SupplyParameterFromForm]
    private string? NewPassword { get; set; }

    [SupplyParameterFromForm]
    private string? ConfirmPassword { get; set; }

    private string? _errorMessage;
    private string? _successMessage;
    private bool _mustChange;

    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    protected override void OnInitialized()
    {
        var claim = HttpContext?.User.FindFirst("MustChangePassword");
        _mustChange = claim is not null && bool.TryParse(claim.Value, out var v) && v;
    }

    private async Task HandleChangePasswordAsync()
    {
        if (HttpContext is null)
        {
            return;
        }

        _errorMessage = null;
        _successMessage = null;

        if (string.IsNullOrEmpty(CurrentPassword) || string.IsNullOrEmpty(NewPassword) || string.IsNullOrEmpty(ConfirmPassword))
        {
            _errorMessage = "すべての項目を入力してください。";
            return;
        }

        if (NewPassword != ConfirmPassword)
        {
            _errorMessage = "新しいパスワードが一致しません。";
            return;
        }

        if (NewPassword.Length < 8)
        {
            _errorMessage = "パスワードは8文字以上で入力してください。";
            return;
        }

        var username = HttpContext.User.Identity?.Name;
        if (string.IsNullOrEmpty(username))
        {
            Navigation.NavigateTo("account/login", forceLoad: true);
            return;
        }

        var user = await UserRepo.GetByUsernameAsync(username);
        if (user is null)
        {
            Navigation.NavigateTo("account/login", forceLoad: true);
            return;
        }

        if (!PasswordHasher.VerifyPassword(CurrentPassword, user.PasswordHash))
        {
            _errorMessage = "現在のパスワードが正しくありません。";
            return;
        }

        user.PasswordHash = PasswordHasher.HashPassword(NewPassword);
        user.MustChangePassword = false;
        await UserRepo.UpdateAsync(user);

        Logger.LogInformation("パスワード変更成功: ユーザー '{Username}'", username);

        // Re-issue cookie without MustChangePassword claim
        var claims = new List<Claim>
        {
            new(ClaimTypes.Name, user.Username),
            new(ClaimTypes.Role, user.Role.ToString()),
            new(ClaimTypes.AuthenticationMethod, "Cookie"),
            new("MustChangePassword", "False"),
        };

        var identity = new ClaimsIdentity(claims, CookieAuthenticationDefaults.AuthenticationScheme);
        var principal = new ClaimsPrincipal(identity);

        await HttpContext.SignInAsync(
            CookieAuthenticationDefaults.AuthenticationScheme,
            principal);

        Navigation.NavigateTo("/", forceLoad: true);
    }
}
